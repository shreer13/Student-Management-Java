import java.io.*;
import java.util.*;

class InvalidAmountException extends Exception {
    public InvalidAmountException(String msg) {
        super(msg);
    }
}

class BankAccount {
    int cid;
    String name;
    double balance;

    BankAccount(int cid, String name, double balance) throws Exception {

        if (cid < 1 || cid > 20)
            throw new Exception("Customer ID must be between 1 and 20");

        if (balance < 1000)
            throw new Exception("Minimum balance should be Rs.1000");

        this.cid = cid;
        this.name = name;
        this.balance = balance;
    }

    void deposit(double amt) throws InvalidAmountException {
        if (amt <= 0)
            throw new InvalidAmountException("Deposit must be positive");

        balance += amt;
        System.out.println("Amount deposited successfully.");
    }

    void withdraw(double amt) throws Exception {

        if (amt <= 0)
            throw new InvalidAmountException("Amount must be positive");

        if (amt > balance)
            throw new Exception("Insufficient balance");

        balance -= amt;
        System.out.println("Withdrawal successful.");
    }

    void display() {
        System.out.println("\nCustomer Details ");
        System.out.println("ID      : " + cid);
        System.out.println("Name    : " + name);
        System.out.println("Balance : Rs." + balance);
    }
}

public class BankApp {

    static Scanner sc = new Scanner(System.in);
    static BankAccount acc = null;

    public static void main(String[] args) {

        int choice;

        do {
            System.out.println("\n BANK MENU ");
            System.out.println("1. Create Account");
            System.out.println("2. Deposit");
            System.out.println("3. Withdraw");
            System.out.println("4. Display");
            System.out.println("5. Save to File");
            System.out.println("6. Exit");
            System.out.print("Enter choice: ");

            choice = sc.nextInt();

            try {

                switch (choice) {

                    case 1:
                        createAccount();
                        break;

                    case 2:
                        if (acc != null) {
                            System.out.print("Enter amount: ");
                            double d = sc.nextDouble();
                            acc.deposit(d);
                        } else {
                            System.out.println("Create account first!");
                        }
                        break;

                    case 3:
                        if (acc != null) {
                            System.out.print("Enter withdrawal amount: ");
                            double w = sc.nextDouble();
                            acc.withdraw(w);
                        } else {
                            System.out.println("No account found!");
                        }
                        break;

                    case 4:
                        if (acc != null)
                            acc.display();
                        else
                            System.out.println("No data available.");
                        break;

                    case 5:
                        saveToFile();
                        break;

                    case 6:
                        System.out.println("Exiting...");
                        break;

                    default:
                        System.out.println("Invalid choice!");
                }

            } catch (Exception e) {
                System.out.println("Error: " + e.getMessage());
            }

        } while (choice != 6);
    }

    static void createAccount() throws Exception {

        System.out.print("Enter Customer ID: ");
        int id = sc.nextInt();
        sc.nextLine(); // clear buffer

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Initial Amount: ");
        double amt = sc.nextDouble();

        acc = new BankAccount(id, name, amt);

        System.out.println("Account created successfully.");
    }

    static void saveToFile() {

        if (acc == null) {
            System.out.println("Nothing to save");
            return;
        }

        try (FileWriter fw = new FileWriter("bank_data.txt", true)) {

            fw.write(acc.cid + "," + acc.name + "," + acc.balance + "\n");

            System.out.println("Data saved to file.");

        } catch (IOException e) {
            System.out.println("File error: " + e.getMessage());
        }
    }
}
